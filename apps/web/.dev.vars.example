# Local development secrets. Copy to .dev.vars and fill in.
# .dev.vars is gitignored. Never commit real secrets.

# Stripe — required for invoicing
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Get from `stripe listen --forward-to localhost:4321/api/webhooks/stripe`
# (NOT the same as the production webhook secret)
STRIPE_WEBHOOK_SECRET=whsec_...
