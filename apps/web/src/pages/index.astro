    <!-- Animated mockup CSS -->
    <style>
      /* Mockup animation keyframes */
      .mockup-step {
        opacity: 0;
        transform: translateY(10px);
      }

      .mockup-step-1 {
        animation: fadeInUp 0.6s ease-out forwards;
        animation-delay: 0.5s;
      }

      .mockup-step-2 {
        animation: fadeInUp 0.6s ease-out forwards;
        animation-delay: 2s;
      }

      .mockup-step-3 {
        animation: fadeInUp 0.6s ease-out forwards;
        animation-delay: 4s;
      }

      .mockup-spinner {
        animation: spin 1s linear infinite;
        animation-delay: 2s;
        opacity: 0;
      }

      .mockup-step-2.mockup-step {
        animation: fadeInUp 0.6s ease-out forwards, fadeOutDown 0.6s ease-out forwards;
        animation-delay: 2s, 3.8s;
      }

      .mockup-progress {
        width: 0%;
        animation: progressFill 1.5s ease-out forwards;
        animation-delay: 2.2s;
      }

      .mockup-confidence {
        animation: confidenceFill 0.8s ease-out forwards;
        animation-delay: 4.5s;
      }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes fadeOutDown {
        from {
          opacity: 1;
          transform: translateY(0);
        }
        to {
          opacity: 0;
          transform: translateY(-10px);
          position: absolute;
          pointer-events: none;
        }
      }

      @keyframes spin {
        from { transform: rotate(0deg); opacity: 1; }
        to { transform: rotate(360deg); opacity: 1; }
      }

      @keyframes progressFill {
        from { width: 0%; }
        to { width: 100%; }
      }

      @keyframes confidenceFill {
        from { width: 0%; }
        to { width: 94%; }
      }
    </style>
