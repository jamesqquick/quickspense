---
// Legacy /receipts/[id] route. Receipts now ARE expenses; the legacy id is
// either a receipt that was finalized (in which case it points to a
// different expense id, but we redirect by id since the id is preserved for
// non-finalized receipts) or a non-finalized receipt whose expense reuses
// the id. The migration preserved ids for the latter; for finalized rows,
// a 301 to /expenses?status=active is the safest fallback since the
// linked expense may not have the receipt's id.
const { id } = Astro.params;
return Astro.redirect(`/expenses/${id}`, 301);
---
