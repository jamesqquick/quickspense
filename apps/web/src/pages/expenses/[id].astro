---
import Layout from "../../layouts/Layout.astro";
import { ExpenseReview } from "../../components/ExpenseReview";

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const { id } = Astro.params;
---

<Layout>
  <div class="mb-4">
    <a
      href="/expenses"
      class="text-sm text-primary-400 hover:text-primary-300 transition-colors duration-200"
      >&larr; Back to Expenses</a
    >
  </div>
  <h1 class="text-2xl font-bold text-white mb-6">Expense</h1>
  <ExpenseReview expenseId={id!} client:load />
</Layout>
