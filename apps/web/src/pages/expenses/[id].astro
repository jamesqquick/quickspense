---
import Layout from "../../layouts/Layout.astro";
import { ExpenseReview } from "../../components/ExpenseReview";
import { expenses, createDb } from "@quickspense/domain";

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const { id } = Astro.params;

// Server-side fetch so we can pick the right page heading without flashing.
// The component re-fetches client-side too for live updates.
const db = createDb(Astro.locals.runtime.env.DB);
const expense = await expenses.getExpense(db, id!, Astro.locals.user.id);

if (!expense) {
  return Astro.redirect("/expenses");
}

const heading =
  expense.status === "needs_review"
    ? "Review Expense"
    : expense.status === "active"
      ? "Edit Expense"
      : "Expense";
---

<Layout>
  <div class="mb-4">
    <a
      href="/expenses"
      class="text-sm text-primary-400 hover:text-primary-300 transition-colors duration-200"
      >&larr; Back to Expenses</a
    >
  </div>
  <h1 class="text-2xl font-bold text-white mb-6">{heading}</h1>
  <ExpenseReview expenseId={id!} client:load />
</Layout>
