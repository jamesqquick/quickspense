---
import "../styles/global.css";

const { user } = Astro.locals;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quickspense</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-surface-900 min-h-screen font-sans">
    {user ? (
      <nav class="glass-strong sticky top-0 z-50">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
          <a href="/" class="text-xl font-bold text-white tracking-tight">Quickspense</a>
          <!-- Desktop nav -->
          <div class="hidden md:flex items-center gap-6">
            <a href="/dashboard" class:list={["text-sm transition-colors duration-200", currentPath === "/dashboard" ? "text-primary-400 font-medium" : "text-slate-400 hover:text-white"]}>Dashboard</a>
            <a href="/receipts" class:list={["text-sm transition-colors duration-200", currentPath.startsWith("/receipts") ? "text-primary-400 font-medium" : "text-slate-400 hover:text-white"]}>Receipts</a>
            <a href="/expenses" class:list={["text-sm transition-colors duration-200", currentPath.startsWith("/expenses") ? "text-primary-400 font-medium" : "text-slate-400 hover:text-white"]}>Expenses</a>
            <a href="/categories" class:list={["text-sm transition-colors duration-200", currentPath.startsWith("/categories") ? "text-primary-400 font-medium" : "text-slate-400 hover:text-white"]}>Categories</a>
            <a href="/settings" class:list={["text-sm transition-colors duration-200", currentPath.startsWith("/settings") ? "text-primary-400 font-medium" : "text-slate-400 hover:text-white"]}>Settings</a>
            <span class="text-sm text-slate-500">{user.email}</span>
            <form method="POST" action="/api/auth/logout">
              <button type="submit" class="text-sm text-red-400 hover:text-red-300 transition-colors duration-200 cursor-pointer">Logout</button>
            </form>
          </div>
          <!-- Mobile menu button -->
          <button id="app-menu-btn" class="md:hidden text-slate-300 hover:text-white cursor-pointer" aria-label="Toggle menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
        <!-- Mobile menu -->
        <div id="app-menu" class="hidden md:hidden px-4 pb-4 space-y-1">
          <a href="/dashboard" class:list={["block text-sm py-2 transition-colors duration-200", currentPath === "/dashboard" ? "text-primary-400 font-medium" : "text-slate-400 hover:text-white"]}>Dashboard</a>
          <a href="/receipts" class:list={["block text-sm py-2 transition-colors duration-200", currentPath.startsWith("/receipts") ? "text-primary-400 font-medium" : "text-slate-400 hover:text-white"]}>Receipts</a>
          <a href="/expenses" class:list={["block text-sm py-2 transition-colors duration-200", currentPath.startsWith("/expenses") ? "text-primary-400 font-medium" : "text-slate-400 hover:text-white"]}>Expenses</a>
          <a href="/categories" class:list={["block text-sm py-2 transition-colors duration-200", currentPath.startsWith("/categories") ? "text-primary-400 font-medium" : "text-slate-400 hover:text-white"]}>Categories</a>
          <a href="/settings" class:list={["block text-sm py-2 transition-colors duration-200", currentPath.startsWith("/settings") ? "text-primary-400 font-medium" : "text-slate-400 hover:text-white"]}>Settings</a>
          <div class="pt-2 border-t border-white/10 flex items-center justify-between">
            <span class="text-sm text-slate-500">{user.email}</span>
            <form method="POST" action="/api/auth/logout">
              <button type="submit" class="text-sm text-red-400 hover:text-red-300 cursor-pointer">Logout</button>
            </form>
          </div>
        </div>
      </nav>
    ) : (
      <nav class="glass-strong sticky top-0 z-50">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
          <a href="/" class="text-xl font-bold text-white tracking-tight">Quickspense</a>
          <div class="flex items-center gap-4">
            <a href="/login" class="text-sm text-slate-400 hover:text-white transition-colors duration-200">Login</a>
            <a href="/register" class="text-sm bg-accent-500 text-white px-4 py-2 rounded-xl hover:bg-accent-600 transition-colors duration-200 font-medium cursor-pointer">Register</a>
          </div>
        </div>
      </nav>
    )}
    <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
      <slot />
    </main>

    <script>
      const btn = document.getElementById("app-menu-btn");
      const menu = document.getElementById("app-menu");
      if (btn && menu) {
        btn.addEventListener("click", () => {
          menu.classList.toggle("hidden");
        });
      }
    </script>
  </body>
</html>
